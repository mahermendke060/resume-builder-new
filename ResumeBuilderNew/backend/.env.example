# Copy to .env and fill in secrets.

ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://resume:resume@localhost:5432/resume
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# OpenRouter — free OSS model. Model id is swappable; verify it's still on the free
# tier at https://openrouter.ai/models (free ids end with ":free").
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free

# SerpApi (Google Jobs discovery)
SERPAPI_KEY=

FILE_STORE_DIR=./var/files
